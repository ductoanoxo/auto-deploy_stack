      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-prom"
          },
          "editorMode": "code",
          "expr": "label_replace(docker_swarm_service_running_replicas, \"service\", \"$1\", \"service_name\", \"(.*)\")",
          "format": "table",
          "instant": true,
          "legendFormat": "Running",
          "range": false,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-prom"
          },
          "editorMode": "code",
          "expr": "label_replace(docker_swarm_service_desired_replicas, \"service\", \"$1\", \"service_name\", \"(.*)\")",
          "format": "table",
          "instant": true,
          "legendFormat": "Desired",
          "range": false,
          "refId": "B"
        }
      ],
      "title": "🐳 Services & Replicas",
      "transformations": [
        {
          "id": "seriesToColumns",
          "options": {
            "byField": "service_name"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "service_name": 0,
              "Value #A": 1,
              "Value #B": 2
            },
            "renameByName": {
              "Value #A": "Running",
              "Value #B": "Desired",
              "service_name": "Service"
            }
          }
        }
      ],
      "type": "table"
    },
